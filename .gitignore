# ---------------------------
# Root Git Ignore
# ---------------------------

# Environment files
.env
*.env
*.env.local

# Node modules (backend + frontend)
server/node_modules/
client/node_modules/

# Build outputs
server/dist/
server/build/
client/dist/
client/build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor folders
.vscode/
.idea/

# OS-specific
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.log

# Package-lock or pnpm-lock (optional)
# Uncomment if you want to ignore lock files
# package-lock.json
# pnpm-lock.yaml
# yarn.lock
